// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "darwin-arm64"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ==================== USER ====================
model User {
  id            String        @id @default(cuid())
  email         String?       @unique
  name          String?
  image         String?
  password      String?
  settings      Settings?
  preferences   UserPreference?
  notificationPreference NotificationPreference?
  pushSubscriptions PushSubscription[]
  notificationSchedules NotificationSchedule[]
  notificationHistory NotificationHistory[]
  favorites     Favorite[]
  history       History[]
  searchHistory SearchHistory[]
  alarms        Alarm[]
  aiChats       AIChat[]
  libraryFiles  LibraryFile[]
  sessions      ListeningSession[]
  devices       Device[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ==================== SETTINGS ====================
model Settings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language           String   @default("ar") // ar or en
  theme              String   @default("light") // light or dark
  notifications      Boolean  @default(true)
  notificationSound  Boolean  @default(true)
  
  // App settings
  islamicMode        Boolean  @default(false)
  selectedCountry    String   @default("EG")
  selectedMood       String?
  contentFilter      String   @default("all") // all, quran, islamic, music, news
  volume             Float    @default(0.7)
  
  // Sleep timer
  sleepTimerMinutes  Int?
  sleepTimerActive   Boolean  @default(false)
  
  // Last state (for smart resume)
  lastStationId      String?
  lastStationName    String?
  lastStationUrl     String?
  lastStationCountry String?
  lastStationFavicon String?
  lastStationTags    String?
  lastCountry        String?
  lastPage           String   @default("all")
  lastFilters        String?  // JSON
  
  // Replay buffer settings
  replayBufferEnabled   Boolean @default(true)
  replayBufferMaxDuration Int    @default(180) // 3 minutes
  
  // Alarm settings
  morningAlarmTime   String?
  morningAlarmEnabled Boolean @default(false)
  eveningAlarmTime   String?
  eveningAlarmEnabled Boolean @default(false)
  repeatEnabled      Boolean  @default(false)
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ==================== USER PREFERENCES ====================
model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Listening statistics
  totalListeningTime    Int      @default(0) // seconds
  sessionsCount         Int      @default(0)
  averageSessionDuration Float   @default(0)
  
  // Category preferences (JSON)
  favoriteCategories    String?  // JSON array
  
  // Top stations (JSON)
  topStations           String?  // JSON array
  
  // Time-based preferences (JSON)
  timePreferences       String?  // JSON array
  
  // Day-based preferences (JSON)
  dayPreferences        String?  // JSON array
  
  // Preferred bitrate
  preferredBitrate      Int      @default(128)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ==================== SEARCH HISTORY ====================
model SearchHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query       String
  resultCount Int      @default(0)
  searchedAt  DateTime @default(now())
  
  @@index([userId, searchedAt])
}

// ==================== RECITERS/PREACHERS ====================
model Reciter {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  image       String?
  bio         String?
  bioAr       String?
  category    String   // quran, lecture, dhikr
  isFeatured  Boolean  @default(false)
  tracks      AudioTrack[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== AUDIO TRACKS ====================
model AudioTrack {
  id            String   @id @default(cuid())
  title         String
  titleAr       String
  description   String?
  descriptionAr String?
  audioUrl      String
  duration      Int      // Duration in seconds
  category      String   // quran, dhikr, lecture, nasheed
  surahNumber   Int?
  surahName     String?
  surahNameAr   String?
  juz           Int?
  reciterId     String?
  reciter       Reciter? @relation(fields: [reciterId], references: [id])
  imageUrl      String?
  playCount     Int      @default(0)
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([category])
  @@index([reciterId])
}

// ==================== RADIO STATIONS ====================
model RadioStation {
  id            String   @id @default(cuid())
  name          String
  nameAr        String
  streamUrl     String
  description   String?
  descriptionAr String?
  imageUrl      String?
  category      String   // quran, islamic, nasheed
  country       String?
  countrycode   String?
  isLive        Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  playCount     Int      @default(0)
  listeners     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([category])
}

// ==================== FAVORITES ====================
model Favorite {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stationId     String   // stationuuid from Radio Browser API
  stationUuid   String?
  stationName   String
  stationUrl    String
  country       String?
  countrycode   String?
  favicon       String?
  tags          String?
  bitrate       Int?
  codec         String?
  votes         Int?
  qualityScore  Float?
  createdAt     DateTime @default(now())
  
  @@unique([userId, stationId])
  @@index([userId])
}

// ==================== HISTORY ====================
model History {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stationId     String   // stationuuid from Radio Browser API
  stationUuid   String?
  stationName   String
  stationUrl    String
  country       String?
  countrycode   String?
  favicon       String?
  tags          String?
  bitrate       Int?
  codec         String?
  votes         Int?
  qualityScore  Float?
  duration      Int?     // Duration played in seconds
  playedAt      DateTime @default(now())
  
  @@index([userId, playedAt])
}

// ==================== LIBRARY FILES ====================
model LibraryFile {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  titleAr     String?
  audioUrl    String
  duration    Int?
  imageUrl    String?
  category    String   // user_upload
  playCount   Int      @default(0)
  createdAt   DateTime @default(now())
  
  @@index([userId])
}

// ==================== ALARMS ====================
model Alarm {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  time        String   // HH:mm format
  type        String   // morning, evening, custom
  enabled     Boolean  @default(true)
  days        String   // JSON array of days [0-6]
  label       String?
  trackId     String?
  stationId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
}

// ==================== AI CHAT HISTORY ====================
model AIChat {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   // user or assistant
  content     String
  contentAr   String?
  action      String?  // play, search, recommend
  stationId   String?
  createdAt   DateTime @default(now())
  
  @@index([userId, createdAt])
}

// ==================== LISTENING SESSION ====================
model ListeningSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stationId   String
  stationName String
  startTime   DateTime  @default(now())
  endTime     DateTime?
  duration    Int?      // Duration in seconds
  category    String?   // quran, dhikr, lecture, nasheed
  mood        String?
  timeOfDay   String?   // morning, afternoon, evening, night, late_night
  dayOfWeek   Int?      // 0-6
  skipped     Boolean   @default(false)
  liked       Boolean   @default(false)
  
  @@index([userId, startTime])
}

// ==================== NOTIFICATION TEMPLATES ====================
model NotificationTemplate {
  id              String   @id @default(cuid())
  type            String   // time_based, behavior, re_engagement, islamic, personal
  category        String   // morning, afternoon, evening, night, quran, dhikr, etc.
  titleAr         String
  titleEn         String
  bodyAr          String
  bodyEn          String
  icon            String?  // emoji or icon URL
  actionTextAr    String?  // "شغّل الآن"
  actionTextEn    String?  // "Play Now"
  deepLink        String?  // Deep link path
  stationId       String?  // Related station if applicable
  stationName     String?
  priority        Int      @default(5) // 1-10
  isActive        Boolean  @default(true)
  variants        NotificationVariant[]
  sentNotifications NotificationHistory[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([type, category])
  @@index([isActive])
}

// ==================== NOTIFICATION VARIANTS (A/B Testing) ====================
model NotificationVariant {
  id             String   @id @default(cuid())
  templateId     String
  template       NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variantName    String   // "A", "B", "C"
  titleAr        String?
  titleEn        String?
  bodyAr         String
  bodyEn         String
  sentCount      Int      @default(0)
  openCount      Int      @default(0)
  clickCount     Int      @default(0)
  conversionCount Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([templateId, variantName])
  @@index([templateId])
}

// ==================== NOTIFICATION SCHEDULE ====================
model NotificationSchedule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String?
  variantId       String?
  type            String   // time_based, behavior, re_engagement, islamic
  scheduledFor    DateTime
  title           String
  body            String
  icon            String?
  actionText      String?
  deepLink        String?
  stationId       String?
  stationName     String?
  status          String   @default("pending") // pending, sent, failed, cancelled
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId, scheduledFor])
  @@index([status, scheduledFor])
}

// ==================== NOTIFICATION HISTORY ====================
model NotificationHistory {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String?
  template        NotificationTemplate? @relation(fields: [templateId], references: [id])
  variantId       String?
  type            String
  title           String
  body            String
  icon            String?
  actionText      String?
  deepLink        String?
  stationId       String?
  stationName     String?
  sentAt          DateTime @default(now())
  openedAt        DateTime?
  clickedAt       DateTime?
  conversionAt    DateTime?
  deviceInfo      String?  // JSON
  createdAt       DateTime @default(now())
  
  @@index([userId, sentAt])
  @@index([type])
}

// ==================== NOTIFICATION PREFERENCES ====================
model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled               Boolean  @default(true)
  morningNotifications  Boolean  @default(true)
  afternoonNotifications Boolean @default(true)
  eveningNotifications  Boolean  @default(true)
  nightNotifications    Boolean  @default(false)
  islamicNotifications  Boolean  @default(true)
  reEngagementNotifications Boolean @default(true)
  behaviorNotifications Boolean  @default(true)
  maxNotificationsPerDay Int    @default(3)
  quietHoursStart       String?  // "22:00"
  quietHoursEnd         String?  // "08:00"
  preferredLanguage     String   @default("ar")
  lastNotificationAt    DateTime?
  totalSentToday        Int      @default(0)
  lastResetDate         DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([userId])
}

// ==================== DEVICE ====================
model Device {
  id          String   @id @default(cuid())
  deviceId    String   @unique
  userId      String?  // Direct link to the owning user (nullable for legacy devices)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  userAgent   String?
  platform    String?  // web, android, ios
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Link to push subscription when user subscribes
  pushSubscription PushSubscription?

  @@index([deviceId])
  @@index([userId])
  @@index([displayName])
}

// ==================== PUSH SUBSCRIPTION ====================
model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String   @unique
  p256dh      String   // Public key
  auth        String   // Auth secret
  userAgent   String?
  deviceId    String?  @unique
  displayName String?  // User's display name for this device
  platform    String?  // web, android, ios
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Link to device
  device      Device?  @relation(fields: [deviceId], references: [deviceId])

  @@index([userId])
  @@index([isActive])
  @@index([displayName])
}

// ==================== NOTIFICATION METRICS ====================
model NotificationMetric {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  templateId      String?
  variantId       String?
  type            String
  totalSent       Int      @default(0)
  totalOpened     Int      @default(0)
  totalClicked    Int      @default(0)
  totalConverted  Int      @default(0)
  openRate        Float    @default(0)
  clickRate       Float    @default(0)
  conversionRate  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([date, type])
  @@index([date])
  @@index([type])
}
